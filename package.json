{
  "name": "20x",
  "version": "0.0.37",
  "packageManager": "pnpm@9.15.2",
  "description": "20x — AI-powered desktop task manager",
  "main": "./out/main/index.js",
  "author": "Peakflo",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build && vite build --config vite.mobile.config.ts",
    "preview": "electron-vite preview",
    "postinstall": "node scripts/rebuild-native.mjs",
    "test": "ELECTRON_RUN_AS_NODE=1 electron ./node_modules/vitest/vitest.mjs",
    "test:run": "ELECTRON_RUN_AS_NODE=1 electron ./node_modules/vitest/vitest.mjs run",
    "test:main": "ELECTRON_RUN_AS_NODE=1 electron ./node_modules/vitest/vitest.mjs --project main",
    "test:renderer": "ELECTRON_RUN_AS_NODE=1 electron ./node_modules/vitest/vitest.mjs --project renderer",
    "lint": "eslint .",
    "typecheck": "tsc --build --noEmit",
    "build:mac": "electron-vite build && vite build --config vite.mobile.config.ts && electron-builder --mac",
    "build:win": "electron-vite build && vite build --config vite.mobile.config.ts && electron-builder --win",
    "build:linux": "electron-vite build && vite build --config vite.mobile.config.ts && electron-builder --linux",
    "prepare": "husky",
    "dev:mobile": "vite --config vite.mobile.config.ts --host",
    "build:mobile": "vite build --config vite.mobile.config.ts",
    "release": "bash scripts/release.sh"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.42",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@opencode-ai/sdk": "^1.1.53",
    "@paralleldrive/cuid2": "^2.2.2",
    "@supabase/supabase-js": "^2.49.4",
    "@zed-industries/claude-code-acp": "^0.16.1",
    "@zed-industries/codex-acp": "^0.9.5",
    "better-sqlite3": "^12.6.2",
    "cron-parser": "^5.5.0",
    "electron-updater": "^6.8.3",
    "js-yaml": "^4.1.1",
    "undici": "^7.21.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@electron/rebuild": "^4.0.3",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-visually-hidden": "^1.2.4",
    "@remotion/bundler": "^4.0.434",
    "@remotion/cli": "^4.0.434",
    "@remotion/renderer": "^4.0.434",
    "@tailwindcss/vite": "^4.0.0",
    "@tanstack/react-virtual": "^3.13.19",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.0.0",
    "eslint": "^10.0.1",
    "happy-dom": "^20.5.0",
    "husky": "^9.1.7",
    "lucide-react": "^0.468.0",
    "png-to-ico": "^3.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "remotion": "^4.0.434",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.56.0",
    "vite": "^6.0.0",
    "vitest": "^4.0.18",
    "zustand": "^5.0.3"
  },
  "pnpm": {
    "overrides": {
      "@zed-industries/claude-code-acp>@anthropic-ai/claude-agent-sdk": "^0.2.42"
    }
  },
  "build": {
    "appId": "com.20x.app",
    "productName": "20x",
    "directories": {
      "buildResources": "resources"
    },
    "files": [
      "out/**/*"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*.node",
      "out/main/mcp-servers/**",
      "out/main/chunks/**"
    ],
    "extraResources": [
      {
        "from": "resources/icon.ico",
        "to": "icon.ico"
      }
    ],
    "afterPack": "./scripts/after-pack.js",
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "installerIcon": "resources/icon.ico",
      "uninstallerIcon": "resources/icon.ico",
      "installerHeaderIcon": "resources/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "20x",
      "uninstallDisplayName": "20x",
      "include": "resources/installer.nsh"
    },
    "nativeRebuilder": "sequential",
    "npmRebuild": true
  }
}
